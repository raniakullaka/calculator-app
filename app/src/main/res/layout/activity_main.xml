<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CALC · 001"
            android:fontFamily="monospace"
            android:textSize="10sp"
            android:textColor="#666666" />
        <TextView
            android:id="@+id/tvModeLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RAD"
            android:fontFamily="monospace"
            android:textSize="9sp"
            android:textColor="#C8FF00"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp"
            android:background="@drawable/badge_outline" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="bottom|end"
        android:paddingHorizontal="24dp"
        android:paddingBottom="12dp">
        <TextView
            android:id="@+id/tvExpression"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:fontFamily="monospace"
            android:textSize="12sp"
            android:textColor="#666666"
            android:maxLines="1"
            android:ellipsize="start" />
        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="0"
            android:fontFamily="monospace"
            android:textSize="42sp"
            android:textStyle="bold"
            android:textColor="#F0F0F0"
            android:maxLines="1"
            android:ellipsize="start" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingBottom="10dp">
        <Button
            android:id="@+id/btnRad"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="RAD"
            android:textSize="9sp"
            android:textColor="#0A0A0A"
            android:backgroundTint="#C8FF00"
            android:layout_marginEnd="8dp"
            style="@style/Widget.Material3.Button.TonalButton" />
        <Button
            android:id="@+id/btnDeg"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:text="DEG"
            android:textSize="9sp"
            android:textColor="#666666"
            android:backgroundTint="#222222"
            android:alpha="0.4"
            style="@style/Widget.Material3.Button.TonalButton" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#222222" />

    <androidx.gridlayout.widget.GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:columnCount="5">

        <Button android:id="@+id/btnSin" style="@style/CalcFnButton" android:text="sin" />
        <Button android:id="@+id/btnCos" style="@style/CalcFnButton" android:text="cos" />
        <Button android:id="@+id/btnTan" style="@style/CalcFnButton" android:text="tan" />
        <Button android:id="@+id/btnLog" style="@style/CalcFnButton" android:text="log" />
        <Button android:id="@+id/btnLn"  style="@style/CalcFnButton" android:text="ln" />

        <Button android:id="@+id/btnSqrt" style="@style/CalcFnButton" android:text="√" />
        <Button android:id="@+id/btnPow2" style="@style/CalcFnButton" android:text="x²" />
        <Button android:id="@+id/btnPow"  style="@style/CalcFnButton" android:text="xʸ" />
        <Button android:id="@+id/btnPi"   style="@style/CalcFnButton" android:text="π" />
        <Button android:id="@+id/btnE"    style="@style/CalcFnButton" android:text="e" />

        <Button android:id="@+id/btnOpenParen"  style="@style/CalcFnButton" android:text="(" />
        <Button android:id="@+id/btnCloseParen" style="@style/CalcFnButton" android:text=")" />
        <Button android:id="@+id/btnPercent"    style="@style/CalcFnButton" android:text="%" />
        <Button android:id="@+id/btnInv"        style="@style/CalcFnButton" android:text="1/x" />
        <Button android:id="@+id/btnClear"      style="@style/CalcDangerButton" android:text="AC" />

        <Button android:id="@+id/btn7" style="@style/CalcNumButton" android:text="7" />
        <Button android:id="@+id/btn8" style="@style/CalcNumButton" android:text="8" />
        <Button android:id="@+id/btn9" style="@style/CalcNumButton" android:text="9" />
        <Button android:id="@+id/btnBackspace" style="@style/CalcDangerButton" android:text="⌫" />
        <Button android:id="@+id/btnDivide" style="@style/CalcOpButton" android:text="÷" />

        <Button android:id="@+id/btn4" style="@style/CalcNumButton" android:text="4" />
        <Button android:id="@+id/btn5" style="@style/CalcNumButton" android:text="5" />
        <Button android:id="@+id/btn6" style="@style/CalcNumButton" android:text="6" />
        <Button android:id="@+id/btnMultiply" style="@style/CalcOpButton" android:text="×" />
        <Button android:id="@+id/btnMinus" style="@style/CalcOpButton" android:text="−" />

        <Button android:id="@+id/btn1" style="@style/CalcNumButton" android:text="1" />
        <Button android:id="@+id/btn2" style="@style/CalcNumButton" android:text="2" />
        <Button android:id="@+id/btn3" style="@style/CalcNumButton" android:text="3" />
        <Button android:id="@+id/btnPlus" style="@style/CalcOpButton" android:text="+" />
        <Button android:id="@+id/btnEquals" style="@style/CalcEqualsButton" android:text="="
            app:layout_rowSpan="2" />

        <Button android:id="@+id/btn0" style="@style/CalcNumButton" android:text="0"
            app:layout_columnSpan="2" android:layout_width="0dp" />
        <Button android:id="@+id/btnDot" style="@style/CalcNumButton" android:text="." />
        <Button android:id="@+id/btnNegate" style="@style/CalcFnButton" android:text="±" />

    </androidx.gridlayout.widget.GridLayout>

    <View android:layout_width="match_parent" android:layout_height="16dp" />

</LinearLayout>
