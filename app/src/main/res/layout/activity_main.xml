<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvExpression"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textColor="#666666"
            android:textSize="14sp"
            android:padding="16dp" />

        <TextView
            android:id="@+id/tvResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:text="0"
            android:textColor="#F0F0F0"
            android:textSize="48sp"
            android:textStyle="bold"
            android:padding="16dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <Button android:id="@+id/btnRad" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RAD" android:layout_margin="8dp" />
            <Button android:id="@+id/btnDeg" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DEG" android:layout_margin="8dp" android:alpha="0.4" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/btnSin" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="sin" android:textColor="#C8FF00" android:backgroundTint="#111111" />
            <Button android:id="@+id/btnCos" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="cos" android:textColor="#C8FF00" android:backgroundTint="#111111" />
            <Button android:id="@+id/btnTan" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="tan" android:textColor="#C8FF00" android:backgroundTint="#111111" />
            <Button android:id="@+id/btnLog" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="log" android:textColor="#C8FF00" android:backgroundTint="#111111" />
            <Button android:id="@+id/btnLn"  android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="ln"  android:textColor="#C8FF00" android:backgroundTint="#111111" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/btnSqrt" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="√"   android:textColor="#C8FF00" android:backgroundTint="#111111" />
            <Button android:id="@+id/btnPow2" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="x2"  android:textColor="#C8FF00" android:backgroundTint="#111111" />
            <Button android:id="@+id/btnPow"  android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="xy"  android:textColor="#C8FF00" android:backgroundTint="#111111" />
            <Button android:id="@+id/btnPi"   android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="pi"  android:textColor="#C8FF00" android:backgroundTint="#111111" />
            <Button android:id="@+id/btnE"    android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="e"   android:textColor="#C8FF00" android:backgroundTint="#111111" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/btnOpenParen"  android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="("   android:textColor="#C8FF00" android:backgroundTint="#111111" />
            <Button android:id="@+id/btnCloseParen" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text=")"   android:textColor="#C8FF00" android:backgroundTint="#111111" />
            <Button android:id="@+id/btnPercent"    android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="%"   android:textColor="#C8FF00" android:backgroundTint="#111111" />
            <Button android:id="@+id/btnInv"        android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="1/x" android:textColor="#C8FF00" android:backgroundTint="#111111" />
            <Button android:id="@+id/btnClear"      android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="AC"  android:textColor="#FF4444" android:backgroundTint="#111111" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/btn7"        android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="7" android:textColor="#F0F0F0" android:backgroundTint="#111111" />
            <Button android:id="@+id/btn8"        android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="8" android:textColor="#F0F0F0" android:backgroundTint="#111111" />
            <Button android:id="@+id/btn9"        android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="9" android:textColor="#F0F0F0" android:backgroundTint="#111111" />
            <Button android:id="@+id/btnBackspace" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="DEL" android:textColor="#FF4444" android:backgroundTint="#111111" />
            <Button android:id="@+id/btnDivide"   android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="/" android:textColor="#F0F0F0" android:backgroundTint="#161616" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/btn4"        android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="4" android:textColor="#F0F0F0" android:backgroundTint="#111111" />
            <Button android:id="@+id/btn5"        android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="5" android:textColor="#F0F0F0" android:backgroundTint="#111111" />
            <Button android:id="@+id/btn6"        android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="6" android:textColor="#F0F0F0" android:backgroundTint="#111111" />
            <Button android:id="@+id/btnMultiply" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="x" android:textColor="#F0F0F0" android:backgroundTint="#161616" />
            <Button android:id="@+id/btnMinus"    android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="-" android:textColor="#F0F0F0" android:backgroundTint="#161616" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/btn1"     android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="1" android:textColor="#F0F0F0" android:backgroundTint="#111111" />
            <Button android:id="@+id/btn2"     android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="2" android:textColor="#F0F0F0" android:backgroundTint="#111111" />
            <Button android:id="@+id/btn3"     android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="3" android:textColor="#F0F0F0" android:backgroundTint="#111111" />
            <Button android:id="@+id/btnPlus"  android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="+" android:textColor="#F0F0F0" android:backgroundTint="#161616" />
            <Button android:id="@+id/btnEquals" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="=" android:textColor="#0A0A0A" android:backgroundTint="#F0F0F0" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
            <Button android:id="@+id/btnNegate" android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="+/-" android:textColor="#C8FF00" android:backgroundTint="#111111" />
            <Button android:id="@+id/btn0"      android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="2" android:text="0"   android:textColor="#F0F0F0" android:backgroundTint="#111111" />
            <Button android:id="@+id/btnDot"    android:layout_width="0dp" android:layout_height="56dp" android:layout_weight="1" android:text="."   android:textColor="#F0F0F0" android:backgroundTint="#111111" />
            <View   android:layout_width="0dp"  android:layout_height="56dp" android:layout_weight="1" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
