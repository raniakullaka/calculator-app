<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.NothingCalculator" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">#C8FF00</item>
        <item name="colorOnPrimary">#0A0A0A</item>
        <item name="colorSurface">#111111</item>
        <item name="android:windowBackground">#0A0A0A</item>
        <item name="android:statusBarColor">#0A0A0A</item>
        <item name="android:navigationBarColor">#0A0A0A</item>
    </style>

    <style name="CalcBaseButton" parent="Widget.Material3.Button.TonalButton">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">58dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:layout_rowWeight">1</item>
        <item name="android:fontFamily">monospace</item>
        <item name="android:textSize">14sp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="cornerRadius">0dp</item>
        <item name="android:layout_margin">0.5dp</item>
    </style>

    <style name="CalcNumButton" parent="CalcBaseButton">
        <item name="android:textColor">#F0F0F0</item>
        <item name="backgroundTint">#111111</item>
    </style>

    <style name="CalcFnButton" parent="CalcBaseButton">
        <item name="android:textColor">#C8FF00</item>
        <item name="android:textSize">12sp</item>
        <item name="backgroundTint">#0F0F0F</item>
    </style>

    <style name="CalcOpButton" parent="CalcBaseButton">
        <item name="android:textColor">#F0F0F0</item>
        <item name="android:textSize">18sp</item>
        <item name="backgroundTint">#161616</item>
    </style>

    <style name="CalcDangerButton" parent="CalcBaseButton">
        <item name="android:textColor">#FF4444</item>
        <item name="backgroundTint">#111111</item>
    </style>

    <style name="CalcEqualsButton" parent="CalcBaseButton">
        <item name="android:textColor">#0A0A0A</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">#F0F0F0</item>
    </style>

</resources>
